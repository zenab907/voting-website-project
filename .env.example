# DEMS — Environment Variables
# Copy this file to .env and fill in your values

# ── Django Core ────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (development)
# Set to your cloud PostgreSQL URL for production
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Examples:
#   Render.com:  postgres://dems_user:secret@dpg-xxx.render.com/dems_db
#   Railway:     postgresql://postgres:secret@containers-us-west-xxx.railway.app:5432/railway
#   Supabase:    postgresql://postgres:secret@db.xxx.supabase.co:5432/postgres

# ── Optional: OpenAI Chatbot Fallback ────────────────────────────────────────
# Set this to enable GPT-4o powered chatbot answers for unrecognised questions
# Leave blank to use keyword-only mode (no API key needed)
OPENAI_API_KEY=

# ── Production CSRF ───────────────────────────────────────────────────────────
# Comma-separated list of trusted origins for CSRF protection
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
